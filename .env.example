# =============================================================================
# Earnings Insight — Environment Variables
# Copy to .env.local for Next.js and ingestion/.env for the Python pipeline
# =============================================================================

# --- OpenAI (server-side only — never expose to client) ---
OPENAI_API_KEY=sk-...

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # server-side only
# Optional: anon key if needed for client-side reads (not required for this app)
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# --- App configuration ---
NEXT_PUBLIC_APP_NAME=Earnings Insight
MAX_QUERY_LENGTH=500
MAX_RETRIEVED_CHUNKS=30
MAX_ANSWER_TOKENS=1500
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW_MS=60000

# --- OpenAI models ---
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- Demo corpus bounds (must match ingested data) ---
DEMO_MIN_PERIOD=2024Q1
DEMO_MAX_PERIOD=2025Q1

# =============================================================================
# Ingestion-only variables (also set in ingestion/.env)
# =============================================================================
INGEST_START_PERIOD=2024Q1
INGEST_END_PERIOD=2025Q1
MAX_TRANSCRIPTS=
EMBEDDING_MODEL=text-embedding-3-small
CHUNK_SIZE_TOKENS=512
CHUNK_OVERLAP_TOKENS=64
CLEANUP_TEMP_FILES=true
EMBEDDING_BATCH_SIZE=100
UPLOAD_BATCH_SIZE=50
